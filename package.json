{
    "name":  "hexo-theme-tangyuxian",
    "version":  "2.0.0-alpha.3.2",
    "description":  "xjh local blog system theme.",
    "keywords":  [
                     "hexo",
                     "theme",
                     "blog-system",
                     "xjh"
                 ],
    "author":  "xjh",
    "license":  "Apache-2.0",
    "main":  "index.js",
    "scripts":  {
                    "lint":  "eslint --ext .jsx --ext .json ",
                    "lint:fix":  "eslint --ext .jsx --ext .json  --fix",
                    "clean":  "npm --prefix demo-site run clean",
                    "generate":  "npm --prefix demo-site run generate",
                    "server":  "npm --prefix demo-site run server",
                    "frontend":  "npm --prefix demo-site run preview",
                    "backend":  "blog-system\\backend\\run-backend.cmd",
                    "start:all":  "start-blog-system.cmd",
                    "check:backend":  "blog-system\\backend\\mvn-local.cmd -q -DskipTests compile",
                    "web":  "start-web.cmd",
                    "web:stop":  "stop-web.cmd"
                },
    "repository":  {
                       "type":  "git",
                       "url":  "local:xjh-blog-system"
                   },
    "bugs":  {
                 "url":  "local:xjh-blog-system/issues"
             },
    "homepage":  "http://127.0.0.1:4000/login.html",
    "devDependencies":  {
                            "eslint":  "^8.6.0",
                            "eslint-config-hexo":  "^5.0.0",
                            "eslint-plugin-json":  "^3.0.0",
                            "eslint-plugin-react":  "^7.17.0"
                        },
    "dependencies":  {
                         "hexo":  "^7.0.0",
                         "hexo-component-inferno":  "^3.0.0",
                         "hexo-generator-json-content":  "^4.2.3",
                         "hexo-renderer-inferno":  "^1.0.2",
                         "hexo-renderer-stylus":  "^3.0.0",
                         "inferno":  "^8.2.3",
                         "inferno-create-element":  "^8.2.3",
                         "semver":  "^7.5.4"
                     },
    "config":  {
                   "commitizen":  {
                                      "path":  "./node_modules/cz-conventional-changelog"
                                  }
               }
}