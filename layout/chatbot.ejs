<% if (theme.chatbot && theme.chatbot.enable) { %>
<div id="ai-chatbot-button" class="ai-chatbot-button" title="<%= theme.chatbot.options.title %>" aria-label="打开 AI 博客助手"></div>
<div id="ai-chatbot-window" class="ai-chatbot-window" aria-label="AI 博客助手窗口">
  <div class="ai-chatbot-header">
    <div class="ai-chatbot-title"><%= theme.chatbot.options.title %></div>
    <button id="ai-chatbot-close" class="ai-chatbot-close" aria-label="关闭">×</button>
  </div>
  <div class="ai-chatbot-content" id="ai-chatbot-content">
    <div id="ai-chatbot-loading" class="ai-chatbot-loading">
      <div class="ai-chatbot-loading-spinner"></div>
      <div class="ai-chatbot-loading-text">正在载入助手...</div>
    </div>
  </div>
</div>

<script>
  (function () {
    const chatbotButton = document.getElementById('ai-chatbot-button');
    const chatbotWindow = document.getElementById('ai-chatbot-window');
    const chatbotClose = document.getElementById('ai-chatbot-close');
    const chatbotContent = document.getElementById('ai-chatbot-content');
    const chatbotLoading = document.getElementById('ai-chatbot-loading');
    let iframeLoaded = false;

    function closeChatbot() {
      chatbotWindow.classList.remove('ai-chatbot-window-open');
      document.body.style.overflow = '';
      document.body.style.touchAction = '';
    }

    function openChatbot() {
      chatbotWindow.classList.add('ai-chatbot-window-open');
      document.body.style.overflow = 'hidden';
      document.body.style.touchAction = 'none';

      if (!iframeLoaded) {
        const iframe = document.createElement('iframe');
        iframe.src = '<%= theme.chatbot.options.chat %>';
        iframe.style.cssText = '<%= theme.chatbot.options.style %>';
        iframe.frameBorder = '0';
        iframe.allow = 'microphone';
        iframe.title = '<%= theme.chatbot.options.title %>';
        iframe.onload = function () {
          chatbotLoading.style.display = 'none';
        };
        chatbotContent.appendChild(iframe);
        iframeLoaded = true;
      }
    }

    chatbotButton.addEventListener('click', function () {
      if (chatbotWindow.classList.contains('ai-chatbot-window-open')) closeChatbot();
      else openChatbot();
    });
    chatbotClose.addEventListener('click', closeChatbot);
    document.addEventListener('keydown', function (event) {
      if (event.key === 'Escape') closeChatbot();
    });
  }());
</script>

<style>
  @keyframes ai-pulse {
    0% { box-shadow: 0 3px 8px rgba(87,48,31,.18), 0 0 0 0 rgba(230,114,73,.25); transform: scale(1); }
    50% { box-shadow: 0 3px 8px rgba(87,48,31,.18), 0 0 0 10px rgba(230,114,73,.12); transform: scale(1.025); }
    100% { box-shadow: 0 3px 8px rgba(87,48,31,.18), 0 0 0 0 rgba(230,114,73,0); transform: scale(1); }
  }
  .ai-chatbot-button {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 5.2rem;
    height: 5.2rem;
    border: 3px solid rgba(255,255,255,.9);
    background-color: #e67249;
    background-image: var(--chat);
    background-size: 100% 100%;
    border-radius: 50%;
    cursor: pointer;
    box-shadow: 0 3px 8px rgba(87,48,31,.18);
    z-index: 9998;
    animation: ai-pulse 2.8s infinite;
  }
  .ai-chatbot-window {
    position: fixed;
    bottom: 8.6rem;
    right: 2rem;
    width: 23.5rem;
    height: 39rem;
    max-width: calc(100vw - 2rem);
    max-height: calc(100vh - 4rem);
    border: 1px solid rgba(230, 114, 73, .24);
    border-radius: 14px;
    background: rgba(255, 250, 246, .96);
    box-shadow: 0 2px 8px rgba(87,48,31,.18);
    z-index: 9999;
    opacity: 0;
    visibility: hidden;
    transform: translateY(14px);
    transition: opacity .2s ease, transform .2s ease, visibility .2s ease;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .ai-chatbot-window-open { opacity: 1; visibility: visible; transform: translateY(0); }
  .ai-chatbot-header {
    padding: .7rem .9rem;
    background: #e67249;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .ai-chatbot-title { color: #fff; font-weight: 750; }
  .ai-chatbot-close {
    width: 30px;
    height: 30px;
    border: 0;
    border-radius: 8px;
    background: rgba(255,255,255,.14);
    color: #fff;
    cursor: pointer;
    font-size: 20px;
    line-height: 1;
  }
  .ai-chatbot-close:hover { background: rgba(255,255,255,.22); }
  .ai-chatbot-content { flex: 1; position: relative; overflow: hidden; }
  .ai-chatbot-loading {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    align-content: center;
    gap: 12px;
    color: #4b382f;
    background: rgba(255, 250, 246, .96);
  }
  .ai-chatbot-loading-spinner {
    width: 38px;
    height: 38px;
    border: 3px solid rgba(230,114,73,.18);
    border-top-color: #e67249;
    border-radius: 50%;
    animation: ai-spin 1s linear infinite;
  }
  @keyframes ai-spin { to { transform: rotate(360deg); } }
  @media (max-width: 768px) {
    .ai-chatbot-button { width: 4.6rem; height: 4.6rem; right: 1rem; bottom: 6.5rem; }
    .ai-chatbot-window { inset: 0; width: 100vw; height: 100vh; max-width: none; max-height: none; border-radius: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .ai-chatbot-button { animation: none; }
    .ai-chatbot-window { transition: none; }
    .ai-chatbot-loading-spinner { animation: none; }
  }
</style>
<% } %>