<section class="nexmoe-memos">
  <div id="memos-wrapper">
    <div id="memos-container">
      <div class="memos-loading"><%= __('memos.loading') %></div>
    </div>
    <div id="memos-load-more" style="display:none; text-align:center; margin-top:30px; margin-bottom:20px;">
      <button class="load-btn"><%= __('memos.more') %></button>
    </div>
  </div>
</section>

<section class="nexmoe-notifications" id="notification-page">
  <div class="notification-wrapper">
    <div class="notification-head">
      <div>
        <p class="notification-kicker">消息通知</p>
        <h2>互动通知</h2>
        <p id="notification-unread-count">正在同步通知...</p>
      </div>
      <div class="notification-actions">
        <button id="notification-refresh" type="button">刷新</button>
        <button id="notification-mark-read" type="button">全部标为已读</button>
      </div>
    </div>
    <p id="notification-status" class="notification-status">登录后可查看评论、回复、关注动态、点赞和私信通知。</p>
    <div id="notification-list" class="notification-list"></div>
  </div>
</section>

<style>
  .nexmoe-memos { padding: 8px 0 24px; }
  #memos-wrapper { max-width: 800px; margin: 0 auto; padding: 0 20px; }
  .memos-loading { padding: 40px; color: var(--color-text-2); text-align: center; }
  .memo-item { display: flex; gap: 10px; padding: 16px 0; border-bottom: 1px solid var(--color-primary-bg); align-items: flex-start; }
  .memo-avatar { flex: 0 0 38px; width: 38px; height: 38px; }
  .memo-avatar img { width: 100%; height: 100%; border-radius: 6px; object-fit: cover; }
  .memo-content-wrapper { flex: 1; min-width: 0; }
  .memo-name { color: var(--color-primary); font-weight: 600; font-size: 15px; margin-bottom: 4px; }
  .memo-text { color: var(--color-text-1); font-size: 15px; line-height: 1.6; white-space: pre-wrap; word-wrap: break-word; }
  .memo-text a { color: var(--color-primary); }
  .memo-meta { color: var(--color-text-2); font-size: 12px; margin-top: 8px; }
  .memo-gallery { display: grid; grid-template-columns: repeat(3, 1fr); gap: 4px; max-width: 420px; margin-top: 8px; }
  .memo-gallery[data-count="1"] { display: block; }
  .memo-gallery img { width: 100%; max-height: 220px; object-fit: cover; border-radius: 6px; }
  .load-btn { background: var(--color-card); border: 1px solid var(--color-primary-bg); color: var(--color-text-2); padding: 6px 28px; border-radius: 6px; cursor: pointer; }
  .nexmoe-notifications { padding: 0 0 36px; }
  .notification-wrapper { max-width: 800px; margin: 0 auto; padding: 18px 20px 0; border-top: 1px solid var(--color-primary-bg); }
  .notification-head { display: flex; justify-content: space-between; gap: 16px; align-items: flex-start; margin-bottom: 12px; }
  .notification-head h2 { margin: 0 0 6px; font-size: 22px; color: var(--color-text-1); }
  .notification-kicker { margin: 0 0 4px; color: var(--color-primary); font-size: 12px; font-weight: 600; letter-spacing: 0; }
  #notification-unread-count { margin: 0; color: var(--color-text-2); font-size: 13px; }
  .notification-actions { display: flex; gap: 8px; flex-wrap: wrap; justify-content: flex-end; }
  .notification-actions button { background: var(--color-card); border: 1px solid var(--color-primary-bg); color: var(--color-text-1); padding: 6px 12px; border-radius: 6px; cursor: pointer; font-size: 13px; }
  .notification-actions button:hover { border-color: var(--color-primary); color: var(--color-primary); }
  .notification-status { margin: 0 0 10px; color: var(--color-text-2); font-size: 13px; }
  .notification-list { display: grid; gap: 10px; }
  .notification-card { position: relative; padding: 12px 14px; border: 1px solid var(--color-primary-bg); border-radius: 8px; background: var(--color-card); }
  .notification-card.is-unread { border-color: rgba(217,45,32,.28); }
  .notification-card strong { display: inline-block; margin-right: 8px; color: var(--color-text-1); font-size: 14px; }
  .notification-card p { margin: 6px 0 8px; color: var(--color-text-1); line-height: 1.6; }
  .notification-card .notification-user-link { color: var(--color-primary); font-weight: 700; text-decoration: none; }
  .notification-card .notification-user-link:hover { text-decoration: underline; }
  .notification-card small { color: var(--color-text-2); }
  .notification-card small a { margin-left: 8px; color: var(--color-primary); }
  .notification-empty { margin: 0; padding: 18px 0; color: var(--color-text-2); text-align: center; }
  @media (max-width: 640px) {
    .notification-head { display: block; }
    .notification-actions { justify-content: flex-start; margin-top: 12px; }
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const CONFIG = {
    host: '<%= theme.memos.host || '' %>',
    pageSize: Number('<%= theme.memos.pageSize || 10 %>'),
    avatarUrl: '<%= theme.memos.avatarUrl || theme.avatar %>',
    nickname: '<%= theme.memos.nickname || config.title %>',
    enableFancybox: <%= theme.memos.enableFancybox === false ? 'false' : 'true' %>,
    filter: '<%= theme.memos.filter || '#memos' %>',
    footer: '<%= theme.memos.footer || '' %>'
  };
  const LOCAL_ITEMS = <%- JSON.stringify(theme.memos.localItems || []) %>;
  const container = document.getElementById('memos-container');
  const loadMore = document.getElementById('memos-load-more');

  function formatTime(value) {
    const date = new Date(value).getTime();
    const seconds = Math.abs(Date.now() - date) / 1000;
    if (seconds < 60) return '<%= __('memos.just_now') %>';
    if (seconds < 3600) return Math.floor(seconds / 60) + ' <%= __('memos.minutes_ago') %>';
    if (seconds < 86400) return Math.floor(seconds / 3600) + ' <%= __('memos.hours_ago') %>';
    if (seconds < 172800) return '<%= __('memos.yesterday') %>';
    return Math.floor(seconds / 86400) + ' <%= __('memos.days_ago') %>';
  }

  function parseContent(text) {
    return String(text || '')
      .replace(new RegExp(CONFIG.filter, 'g'), '')
      .replace(/!\[([^\]]*)\]\(([^)]+)\)/g, '<a href="$2" data-fancybox="memos"><img src="$2" alt="$1" loading="lazy"></a>')
      .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>')
      .replace(/#(\S+)/g, '<span style="color:var(--color-primary)">#$1</span>');
  }

  function renderItems(items) {
    container.innerHTML = '';
    if (!items.length) {
      container.innerHTML = '<div class="memos-loading"><%= __('memos.no_dynamic') %></div>';
      return;
    }
    items.forEach(function (item) {
      const html = '<div class="memo-item">'
        + '<div class="memo-avatar"><img src="' + CONFIG.avatarUrl + '" alt="avatar"></div>'
        + '<div class="memo-content-wrapper">'
        + '<div class="memo-name">' + CONFIG.nickname + '</div>'
        + '<div class="memo-text">' + parseContent(item.content || '') + '</div>'
        + '<div class="memo-meta">' + formatTime(item.createTime || new Date()) + '</div>'
        + '</div></div>';
      container.insertAdjacentHTML('beforeend', html);
    });
    loadMore.style.display = 'none';
  }

  async function loadRemoteMemos() {
    try {
      const url = CONFIG.host + '/api/v1/memos?pageSize=' + CONFIG.pageSize + '&filter=content.contains(' + encodeURIComponent("'" + CONFIG.filter + "'") + ')';
      const res = await fetch(url);
      if (!res.ok) throw new Error('Request failed');
      const data = await res.json();
      renderItems(data.memos || []);
    } catch (error) {
      console.error(error);
      renderItems(LOCAL_ITEMS);
    }
  }

  if (CONFIG.host) loadRemoteMemos();
  else renderItems(LOCAL_ITEMS);

  if (CONFIG.footer) {
    const footer = document.createElement('div');
    footer.style.cssText = 'text-align:center;margin:16px 0 0;font-size:12px;color:var(--color-text-2)';
    footer.textContent = CONFIG.footer;
    document.getElementById('memos-wrapper').appendChild(footer);
  }
});
</script>
<script src="/js/blog-api.js"></script>
