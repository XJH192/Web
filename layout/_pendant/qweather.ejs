  }
  .xjh-weather-head,
  .xjh-weather-main,
  .xjh-weather-meta,
  .xjh-weather-controls,
  .xjh-weather-search,
  .xjh-weather-forecast {
    display: flex;
    align-items: center;
  }
  .xjh-weather-head { justify-content: space-between; gap: 8px; }
  .xjh-weather-head strong { display: block; color: #2b211d; font-size: 14px; }
