    flex: 0 0 auto;
  }
  .xjh-weather-main b { display: block; color: #2b211d; font-size: 26px; line-height: 1; }
  .xjh-weather-main span { color: #5d4a40; font-size: 12px; line-height: 1.5; }
  .xjh-weather-meta { flex-wrap: wrap; gap: 5px; }
  .xjh-weather-meta span,
  .xjh-weather-forecast span {
    border-radius: 999px;
    padding: 4px 7px;
    background: rgba(230, 114, 73, .1);
    color: #63483b;
    font-size: 12px;
    line-height: 1.2;
  }
  .xjh-weather-forecast { flex-wrap: wrap; gap: 5px; margin-top: 8px; }
  .xjh-weather-forecast b { margin-right: 4px; color: #d8663f; }
  .xjh-weather-controls { align-items: stretch; flex-direction: column; gap: 7px; margin-top: 10px; }
  .xjh-weather-controls input {
    min-width: 0;
    flex: 1;
    min-height: 34px;
    border: 1px solid rgba(230, 114, 73, .24);
    border-radius: 9px;
    padding: 0 9px;
    background: #fff;
    color: #30231d;
    font: inherit;
    font-size: 13px;
    outline: none;
  }
  .xjh-weather-controls input:focus {
    border-color: #e67249;
    box-shadow: 0 0 0 3px rgba(230, 114, 73, .14);
  }
  .xjh-weather-search { gap: 7px; }
  .xjh-weather-search button,
  .xjh-weather-link {
    min-height: 34px;
    border: 0;
    border-radius: 9px;
    padding: 0 11px;
    background: #e67249;
    color: #fff;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font: inherit;
    font-size: 13px;
    font-weight: 750;
    text-decoration: none;
    white-space: nowrap;
  }
  .xjh-weather-link { background: rgba(230, 114, 73, .12); color: #c95531; }
  .xjh-weather-source { margin: 8px 0 0; line-height: 1.5; }
</style>