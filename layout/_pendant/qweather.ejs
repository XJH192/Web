    font: inherit;
  }
  .xjh-weather-main { gap: 10px; margin: 10px 0; }
  .xjh-weather-icon {
    display: grid;
    place-items: center;
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: #ff936f;
