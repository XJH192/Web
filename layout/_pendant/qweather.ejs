  .xjh-weather-controls input {
    min-width: 0;
    flex: 1;
    min-height: 34px;
    border: 1px solid rgba(230, 114, 73, .24);
    border-radius: 9px;
    padding: 0 9px;
    background: #fff;
    color: #30231d;
    font: inherit;
    font-size: 13px;
    outline: none;
  }
  .xjh-weather-controls input:focus {
    border-color: #e67249;
    box-shadow: 0 0 0 3px rgba(230, 114, 73, .14);
  }
  .xjh-weather-search button,
  .xjh-weather-link {
    min-height: 34px;
    border: 0;
    border-radius: 9px;
    padding: 0 11px;
    background: #e67249;
    color: #fff;
