<div class="nexmoe-pd-item xjh-weather-wrap">
  <section class="xjh-weather-card" aria-label="实时天气">
    <div class="xjh-weather-head">
      <div>
        <strong id="xjh-weather-city">青岛崂山区</strong>
        <span id="xjh-weather-desc">实时天气</span>
      </div>
      <button id="xjh-weather-refresh" type="button" aria-label="刷新天气">↻</button>
    </div>
    <div class="xjh-weather-main">
      <div class="xjh-weather-icon" id="xjh-weather-icon">待</div>
      <div>
        <b id="xjh-weather-temp">待更新</b>
        <span id="xjh-weather-detail">正在获取天气...</span>
      </div>
    </div>
    <div class="xjh-weather-meta">
      <span id="xjh-weather-feels">体感待更新</span>
      <span id="xjh-weather-humidity">湿度待更新</span>
      <span id="xjh-weather-wind">风速待更新</span>
    </div>
    <div class="xjh-weather-forecast" id="xjh-weather-forecast"></div>
    <div class="xjh-weather-controls">
      <div class="xjh-weather-search">
        <input id="xjh-weather-input" type="search" list="xjh-weather-options" placeholder="输入城市或区县">
        <datalist id="xjh-weather-options"></datalist>
        <button id="xjh-weather-search-btn" type="button">查询</button>
      </div>
      <a id="xjh-weather-link" class="xjh-weather-link" href="https://weather.cma.cn/web/weather/54857.html" target="_blank" rel="noopener">打开天气网站</a>
    </div>
    <p class="xjh-weather-source" id="xjh-weather-status">数据源 Open-Meteo，按北京时间更新。</p>
  </section>
</div>

<script>
  (function () {
    const presetList = [
      { name: '青岛崂山区', latitude: 36.107, longitude: 120.468, link: 'https://weather.cma.cn/web/weather/54857.html' },
      { name: '青岛市南区', latitude: 36.066, longitude: 120.382, link: 'https://weather.cma.cn/web/weather/54857.html' },
      { name: '青岛市北区', latitude: 36.087, longitude: 120.374, link: 'https://weather.cma.cn/web/weather/54857.html' },
      { name: '青岛李沧区', latitude: 36.145, longitude: 120.432, link: 'https://weather.cma.cn/web/weather/54857.html' },
      { name: '北京市', latitude: 39.904, longitude: 116.407, link: 'https://weather.cma.cn/web/weather/54511.html' },
      { name: '北京海淀区', latitude: 39.960, longitude: 116.298, link: 'https://weather.cma.cn/web/weather/54399.html' },
      { name: '北京朝阳区', latitude: 39.921, longitude: 116.443, link: 'https://weather.cma.cn/web/weather/54433.html' },
      { name: '上海市', latitude: 31.231, longitude: 121.474, link: 'https://weather.cma.cn/web/weather/58362.html' },
      { name: '广州天河区', latitude: 23.135, longitude: 113.361, link: 'https://weather.cma.cn/web/weather/59287.html' },
      { name: '深圳南山区', latitude: 22.533, longitude: 113.930, link: 'https://weather.cma.cn/web/weather/59493.html' },
      { name: '杭州西湖区', latitude: 30.259, longitude: 120.130, link: 'https://weather.cma.cn/web/weather/58457.html' },
      { name: '南京鼓楼区', latitude: 32.067, longitude: 118.769, link: 'https://weather.cma.cn/web/weather/58238.html' },
      { name: '成都武侯区', latitude: 30.642, longitude: 104.043, link: 'https://weather.cma.cn/web/weather/56294.html' },
      { name: '西安雁塔区', latitude: 34.213, longitude: 108.948, link: 'https://weather.cma.cn/web/weather/57036.html' },
      { name: '武汉洪山区', latitude: 30.500, longitude: 114.343, link: 'https://weather.cma.cn/web/weather/57494.html' }
    ];
    const els = {
      city: document.getElementById('xjh-weather-city'),
      desc: document.getElementById('xjh-weather-desc'),
      icon: document.getElementById('xjh-weather-icon'),
      temp: document.getElementById('xjh-weather-temp'),
      detail: document.getElementById('xjh-weather-detail'),
      feels: document.getElementById('xjh-weather-feels'),
      humidity: document.getElementById('xjh-weather-humidity'),
      wind: document.getElementById('xjh-weather-wind'),
      forecast: document.getElementById('xjh-weather-forecast'),
      input: document.getElementById('xjh-weather-input'),
      options: document.getElementById('xjh-weather-options'),
      search: document.getElementById('xjh-weather-search-btn'),
      refresh: document.getElementById('xjh-weather-refresh'),
      status: document.getElementById('xjh-weather-status'),
      link: document.getElementById('xjh-weather-link')
    };
    const codeMap = {
      0: ['晴', '晴'], 1: ['晴间多云', '晴'], 2: ['多云', '云'], 3: ['阴', '阴'],
      45: ['有雾', '雾'], 48: ['雾凇', '雾'], 51: ['小雨', '雨'], 53: ['小雨', '雨'], 55: ['小雨', '雨'],
      61: ['小雨', '雨'], 63: ['中雨', '雨'], 65: ['大雨', '雨'], 71: ['小雪', '雪'], 73: ['中雪', '雪'], 75: ['大雪', '雪'],
      80: ['阵雨', '雨'], 81: ['阵雨', '雨'], 82: ['强阵雨', '雨'], 95: ['雷雨', '雷'], 96: ['雷雨', '雷'], 99: ['强雷雨', '雷']
    };
    let activeLocation = presetList[0];
    let searchTimer = null;

    function weatherLabel(code) { return codeMap[code] || ['天气变化', '天']; }
    function setStatus(text) { els.status.textContent = text; }
    function formatDate(value) {
      const date = new Date(value + 'T00:00:00+08:00');
      return new Intl.DateTimeFormat('zh-CN', { timeZone: 'Asia/Shanghai', weekday: 'short' }).format(date);
    }
    function normalize(text) { return String(text || '').replace(/市|区|县|省/g, '').toLowerCase(); }
    function localMatches(keyword) {
      const key = normalize(keyword);
      if (!key) return presetList.slice(0, 8);
      return presetList.filter(function (item) {
        return item.name.indexOf(keyword) >= 0 || normalize(item.name).indexOf(key) >= 0;
      }).slice(0, 8);
    }
    function renderOptions(items) {
      els.options.innerHTML = items.map(function (item) {
        return '<option value="' + item.name.replace(/"/g, '&quot;') + '"></option>';
      }).join('');
    }
    async function remoteMatches(keyword) {
      const url = 'https://geocoding-api.open-meteo.com/v1/search?count=6&language=zh&format=json&name=' + encodeURIComponent(keyword);
      const response = await fetch(url);
      if (!response.ok) return [];
      const data = await response.json();
      return (data.results || []).map(function (city) {
        const label = city.admin1 && city.admin1 !== city.name ? city.name + ' · ' + city.admin1 : city.name;
        return { name: label, latitude: city.latitude, longitude: city.longitude, link: 'https://weather.cma.cn/' };
      });
    }
    async function resolveLocation(name) {
      const exact = presetList.find(function (item) { return item.name === name; });
      if (exact) return exact;
      const fuzzy = localMatches(name)[0];
      if (fuzzy) return fuzzy;
      const remote = await remoteMatches(name);
      if (remote.length) return remote[0];
      throw new Error('没有找到这个城市或区县');
    }
    async function updateSuggestions(keyword) {
      const locals = localMatches(keyword);
      renderOptions(locals);
      if (!keyword || keyword.trim().length < 2) return;
      try {
        const remotes = await remoteMatches(keyword.trim());
        renderOptions(locals.concat(remotes).slice(0, 10));
      } catch (error) {}
    }
    async function loadWeather(location) {
      activeLocation = location;
      els.city.textContent = location.name;
      els.input.value = location.name;
      els.link.href = location.link || 'https://weather.cma.cn/';
      els.desc.textContent = '正在更新';
      els.detail.textContent = '读取实时天气...';
      setStatus('正在连接天气服务...');
      const params = new URLSearchParams({
        latitude: location.latitude,
        longitude: location.longitude,
        current: 'temperature_2m,relative_humidity_2m,apparent_temperature,weather_code,wind_speed_10m',
        daily: 'weather_code,temperature_2m_max,temperature_2m_min',
        timezone: 'Asia/Shanghai',
        forecast_days: '2'
      });
      const response = await fetch('https://api.open-meteo.com/v1/forecast?' + params.toString());
      if (!response.ok) throw new Error('天气服务暂不可用');
      const data = await response.json();
      const current = data.current || {};
      const label = weatherLabel(current.weather_code);
      els.icon.textContent = label[1];
      els.temp.textContent = Math.round(current.temperature_2m) + '°';
      els.detail.textContent = label[0] + ' · ' + (current.time || '').replace('T', ' ');
      els.feels.textContent = '体感 ' + Math.round(current.apparent_temperature) + '°';
      els.humidity.textContent = '湿度 ' + Math.round(current.relative_humidity_2m) + '%';
      els.wind.textContent = '风速 ' + Math.round(current.wind_speed_10m) + 'km/h';
      els.desc.textContent = '实时天气';
      els.forecast.innerHTML = (data.daily && data.daily.time ? data.daily.time : []).map(function (day, index) {
        const text = weatherLabel(data.daily.weather_code[index])[0];
        return '<span><b>' + formatDate(day) + '</b>' + text + ' ' + Math.round(data.daily.temperature_2m_min[index]) + '°/' + Math.round(data.daily.temperature_2m_max[index]) + '°</span>';
      }).join('');
      localStorage.setItem('xjhWeatherCity', location.name);
      setStatus('已按北京时间更新');
    }
    async function submitSearch() {
      const keyword = els.input.value.trim() || '青岛崂山区';
      try {
        const location = await resolveLocation(keyword);
        await loadWeather(location);
      } catch (error) {
        els.desc.textContent = '天气异常';
        els.detail.textContent = error.message;
        setStatus('可以换一个城市或区县名称再试。');
      }
    }

    renderOptions(presetList.slice(0, 8));
    els.input.addEventListener('input', function () {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(function () { updateSuggestions(els.input.value); }, 220);
    });
    els.input.addEventListener('keydown', function (event) {
      if (event.key === 'Enter') submitSearch();
    });
    els.search.addEventListener('click', submitSearch);
    els.refresh.addEventListener('click', function () { loadWeather(activeLocation); });

    const saved = localStorage.getItem('xjhWeatherCity') || '青岛崂山区';
    resolveLocation(saved).then(loadWeather).catch(function () { loadWeather(presetList[0]); });
  }());
</script>

