<div class="nexmoe-pd-item xjh-weather-wrap">
  <section class="xjh-weather-card" aria-label="实时天气">
    <div class="xjh-weather-head">
      <div>
        <strong id="xjh-weather-city">青岛崂山区</strong>
        <span id="xjh-weather-desc">实时天气</span>
      </div>
      <button id="xjh-weather-refresh" type="button" aria-label="刷新天气">↻</button>
    </div>
    <div class="xjh-weather-main">
      <div class="xjh-weather-icon" id="xjh-weather-icon">待</div>
      <div>
        <b id="xjh-weather-temp">待更新</b>
        <span id="xjh-weather-detail">正在获取天气...</span>
      </div>
    </div>
    <div class="xjh-weather-meta">
      <span id="xjh-weather-feels">体感待更新</span>
      <span id="xjh-weather-humidity">湿度待更新</span>
      <span id="xjh-weather-wind">风速待更新</span>
    </div>
    <div class="xjh-weather-forecast" id="xjh-weather-forecast"></div>
    <div class="xjh-weather-controls">
      <div class="xjh-weather-search" id="xjh-weather-searchbox">
        <input id="xjh-weather-input" type="search" autocomplete="off" role="combobox" aria-expanded="false" aria-controls="xjh-weather-suggestions" placeholder="输入城市或区县">
        <button id="xjh-weather-search-btn" type="button">查询</button>
        <div id="xjh-weather-suggestions" class="xjh-weather-suggestions" role="listbox" hidden></div>
      </div>
      <a id="xjh-weather-link" class="xjh-weather-link" href="https://weather.cma.cn/web/weather/54857.html" target="_blank" rel="noopener">打开天气网站</a>
    </div>
    <p class="xjh-weather-source" id="xjh-weather-status">数据源 Open-Meteo，按北京时间更新。</p>
  </section>
</div>

<script>
  (function () {
    const presetList = [
      { name: '青岛崂山区', latitude: 36.107, longitude: 120.468, link: 'https://weather.cma.cn/web/weather/54857.html', aliases: ['崂山', '青岛崂山', 'laoshan'] },
      { name: '青岛市南区', latitude: 36.066, longitude: 120.382, link: 'https://weather.cma.cn/web/weather/54857.html', aliases: ['市南', '青岛市南'] },
      { name: '青岛市北区', latitude: 36.087, longitude: 120.374, link: 'https://weather.cma.cn/web/weather/54857.html', aliases: ['市北', '青岛市北'] },
      { name: '青岛李沧区', latitude: 36.145, longitude: 120.432, link: 'https://weather.cma.cn/web/weather/54857.html', aliases: ['李沧', '青岛李沧'] },
      { name: '北京市', latitude: 39.904, longitude: 116.407, link: 'https://weather.cma.cn/web/weather/54511.html', aliases: ['北京', 'beijing'] },
      { name: '北京海淀区', latitude: 39.960, longitude: 116.298, link: 'https://weather.cma.cn/web/weather/54399.html', aliases: ['海淀', '北京海淀'] },
      { name: '北京朝阳区', latitude: 39.921, longitude: 116.443, link: 'https://weather.cma.cn/web/weather/54433.html', aliases: ['朝阳', '北京朝阳'] },
      { name: '上海市', latitude: 31.231, longitude: 121.474, link: 'https://weather.cma.cn/web/weather/58362.html', aliases: ['上海', 'shanghai'] },
      { name: '广州天河区', latitude: 23.135, longitude: 113.361, link: 'https://weather.cma.cn/web/weather/59287.html', aliases: ['天河', '广州天河', '河'] },
      { name: '深圳南山区', latitude: 22.533, longitude: 113.930, link: 'https://weather.cma.cn/web/weather/59493.html', aliases: ['南山', '深圳南山'] },
      { name: '杭州西湖区', latitude: 30.259, longitude: 120.130, link: 'https://weather.cma.cn/web/weather/58457.html', aliases: ['西湖', '杭州西湖'] },
      { name: '南京鼓楼区', latitude: 32.067, longitude: 118.769, link: 'https://weather.cma.cn/web/weather/58238.html', aliases: ['鼓楼', '南京鼓楼'] },
      { name: '成都武侯区', latitude: 30.642, longitude: 104.043, link: 'https://weather.cma.cn/web/weather/56294.html', aliases: ['武侯', '成都武侯'] },
      { name: '西安雁塔区', latitude: 34.213, longitude: 108.948, link: 'https://weather.cma.cn/web/weather/57036.html', aliases: ['雁塔', '西安雁塔'] },
      { name: '武汉洪山区', latitude: 30.500, longitude: 114.343, link: 'https://weather.cma.cn/web/weather/57494.html', aliases: ['洪山', '武汉洪山'] }
    ];
    const els = {
      city: document.getElementById('xjh-weather-city'),
      desc: document.getElementById('xjh-weather-desc'),
      icon: document.getElementById('xjh-weather-icon'),
      temp: document.getElementById('xjh-weather-temp'),
      detail: document.getElementById('xjh-weather-detail'),
      feels: document.getElementById('xjh-weather-feels'),
      humidity: document.getElementById('xjh-weather-humidity'),
      wind: document.getElementById('xjh-weather-wind'),
      forecast: document.getElementById('xjh-weather-forecast'),
      input: document.getElementById('xjh-weather-input'),
      search: document.getElementById('xjh-weather-search-btn'),
      refresh: document.getElementById('xjh-weather-refresh'),
      status: document.getElementById('xjh-weather-status'),
      link: document.getElementById('xjh-weather-link'),
      suggestions: document.getElementById('xjh-weather-suggestions')
    };
    const codeMap = {
      0: ['晴', '晴'], 1: ['晴间多云', '晴'], 2: ['多云', '云'], 3: ['阴', '阴'],
      45: ['有雾', '雾'], 48: ['雾凇', '雾'], 51: ['小雨', '雨'], 53: ['小雨', '雨'], 55: ['小雨', '雨'],
      61: ['小雨', '雨'], 63: ['中雨', '雨'], 65: ['大雨', '雨'], 71: ['小雪', '雪'], 73: ['中雪', '雪'], 75: ['大雪', '雪'],
      80: ['阵雨', '雨'], 81: ['阵雨', '雨'], 82: ['强阵雨', '雨'], 95: ['雷雨', '雷'], 96: ['雷雨', '雷'], 99: ['强雷雨', '雷']
    };
    let activeLocation = presetList[0];
    let searchTimer = null;
    let currentSuggestions = [];
    let activeIndex = -1;

    function weatherLabel(code) { return codeMap[code] || ['天气变化', '天']; }
    function setStatus(text) { els.status.textContent = text; }
    function formatDate(value) {
      const date = new Date(value + 'T00:00:00+08:00');
      return new Intl.DateTimeFormat('zh-CN', { timeZone: 'Asia/Shanghai', weekday: 'short' }).format(date);
    }
    function normalize(text) { return String(text || '').replace(/[\s·,，。市区县省]/g, '').toLowerCase(); }
    function scoreLocation(item, keyword) {
      const key = normalize(keyword);
      if (!key) return 1;
      const names = [item.name].concat(item.aliases || []).map(normalize);
      let best = 0;
      names.forEach(function (name) {
        if (name === key) best = Math.max(best, 100);
        else if (name.indexOf(key) === 0) best = Math.max(best, 80);
        else if (name.indexOf(key) >= 0) best = Math.max(best, 60);
        else {
          let hit = 0;
          key.split('').forEach(function (ch) { if (name.indexOf(ch) >= 0) hit += 1; });
          if (hit === key.length) best = Math.max(best, 40 + hit);
        }
      });
      return best;
    }
    function uniqueLocations(items) {
      const seen = {};
      return items.filter(function (item) {
        const key = normalize(item.name);
        if (seen[key]) return false;
        seen[key] = true;
        return true;
      });
    }
    function localMatches(keyword) {
      return presetList
        .map(function (item) { return Object.assign({ score: scoreLocation(item, keyword) }, item); })
        .filter(function (item) { return !keyword || item.score > 0; })
        .sort(function (a, b) { return b.score - a.score || a.name.length - b.name.length; })
        .slice(0, 8);
    }
    function escapeHtml(value) {
      return String(value == null ? '' : value).replace(/[&<>"']/g, function (ch) {
        return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' }[ch];
      });
    }
    function renderSuggestions(items, keyword, nextIndex) {
      currentSuggestions = uniqueLocations(items).slice(0, 8);
      if (currentSuggestions.length) {
        activeIndex = typeof nextIndex === 'number' ? Math.max(0, Math.min(nextIndex, currentSuggestions.length - 1)) : 0;
      } else {
        activeIndex = -1;
      }
      if (!currentSuggestions.length) {
        els.suggestions.innerHTML = '<div class="xjh-weather-empty">没有匹配结果，按查询可尝试联网搜索。</div>';
      } else {
        els.suggestions.innerHTML = currentSuggestions.map(function (item, index) {
          const active = index === activeIndex ? ' is-active' : '';
          const sub = item.link && item.link.indexOf('weather.cma.cn/web/weather') >= 0 ? '可打开中央气象台详情' : '联网匹配结果';
          return '<button type="button" class="xjh-weather-option' + active + '" data-weather-index="' + index + '" role="option"><span>' + escapeHtml(item.name) + '</span><small>' + escapeHtml(sub) + '</small></button>';
        }).join('');
      }
      els.suggestions.hidden = false;
      els.input.setAttribute('aria-expanded', 'true');
    }
    function hideSuggestions() {
      els.suggestions.hidden = true;
      els.input.setAttribute('aria-expanded', 'false');
    }
    async function remoteMatches(keyword) {
      const url = 'https://geocoding-api.open-meteo.com/v1/search?count=6&language=zh&format=json&name=' + encodeURIComponent(keyword);
      const response = await fetch(url);
      if (!response.ok) return [];
      const data = await response.json();
      return (data.results || []).map(function (city) {
        const label = city.admin1 && city.admin1 !== city.name ? city.name + ' · ' + city.admin1 : city.name;
        return { name: label, latitude: city.latitude, longitude: city.longitude, link: 'https://weather.cma.cn/' };
      });
    }
    async function resolveLocation(name) {
      const exact = presetList.find(function (item) { return normalize(item.name) === normalize(name); });
      if (exact) return exact;
      const local = localMatches(name)[0];
      if (local && local.score >= 40) return local;
      const remote = await remoteMatches(name);
      if (remote.length) return remote[0];
      throw new Error('没有找到这个城市或区县');
    }
    async function updateSuggestions(keyword) {
      const locals = localMatches(keyword);
      renderSuggestions(locals, keyword);
      if (!keyword || keyword.trim().length < 2) return;
      try {
        const remotes = await remoteMatches(keyword.trim());
        renderSuggestions(locals.concat(remotes), keyword);
      } catch (error) {}
    }
    async function loadWeather(location) {
      activeLocation = location;
      els.city.textContent = location.name;
      els.input.value = location.name;
      els.link.href = location.link || 'https://weather.cma.cn/';
      els.desc.textContent = '正在更新';
      els.detail.textContent = '读取实时天气...';
      setStatus('正在连接天气服务...');
      hideSuggestions();
      const params = new URLSearchParams({
        latitude: location.latitude,
        longitude: location.longitude,
        current: 'temperature_2m,relative_humidity_2m,apparent_temperature,weather_code,wind_speed_10m',
        daily: 'weather_code,temperature_2m_max,temperature_2m_min',
        timezone: 'Asia/Shanghai',
        forecast_days: '2'
      });
      const response = await fetch('https://api.open-meteo.com/v1/forecast?' + params.toString());
      if (!response.ok) throw new Error('天气服务暂不可用');
      const data = await response.json();
      const current = data.current || {};
      const label = weatherLabel(current.weather_code);
      els.icon.textContent = label[1];
      els.temp.textContent = Math.round(current.temperature_2m) + '°';
      els.detail.textContent = label[0] + ' · ' + (current.time || '').replace('T', ' ');
      els.feels.textContent = '体感 ' + Math.round(current.apparent_temperature) + '°';
      els.humidity.textContent = '湿度 ' + Math.round(current.relative_humidity_2m) + '%';
      els.wind.textContent = '风速 ' + Math.round(current.wind_speed_10m) + 'km/h';
      els.desc.textContent = '实时天气';
      els.forecast.innerHTML = (data.daily && data.daily.time ? data.daily.time : []).map(function (day, index) {
        const text = weatherLabel(data.daily.weather_code[index])[0];
        return '<span><b>' + formatDate(day) + '</b>' + text + ' ' + Math.round(data.daily.temperature_2m_min[index]) + '°/' + Math.round(data.daily.temperature_2m_max[index]) + '°</span>';
      }).join('');
      localStorage.setItem('xjhWeatherCity', location.name);
      setStatus('已按北京时间更新');
    }
    async function submitSearch() {
      const keyword = els.input.value.trim() || '青岛崂山区';
      try {
        const selected = !els.suggestions.hidden && currentSuggestions[activeIndex] ? currentSuggestions[activeIndex] : null;
        const location = selected || await resolveLocation(keyword);
        await loadWeather(location);
      } catch (error) {
        els.desc.textContent = '天气异常';
        els.detail.textContent = error.message;
        setStatus('可以换一个城市或区县名称再试。');
      }
    }
    function moveActive(delta) {
      if (!currentSuggestions.length) return;
      const nextIndex = (activeIndex + delta + currentSuggestions.length) % currentSuggestions.length;
      renderSuggestions(currentSuggestions, els.input.value, nextIndex);
    }

    els.input.addEventListener('focus', function () { updateSuggestions(els.input.value); });
    els.input.addEventListener('input', function () {
      clearTimeout(searchTimer);
      renderSuggestions(localMatches(els.input.value), els.input.value);
      searchTimer = setTimeout(function () { updateSuggestions(els.input.value); }, 180);
    });
    els.input.addEventListener('keydown', function (event) {
      if (event.key === 'ArrowDown') { event.preventDefault(); moveActive(1); }
      if (event.key === 'ArrowUp') { event.preventDefault(); moveActive(-1); }
      if (event.key === 'Enter') { event.preventDefault(); submitSearch(); }
      if (event.key === 'Escape') hideSuggestions();
    });
    els.suggestions.addEventListener('mousedown', function (event) {
      const option = event.target.closest('[data-weather-index]');
      if (!option) return;
      event.preventDefault();
      const location = currentSuggestions[Number(option.getAttribute('data-weather-index'))];
      if (location) loadWeather(location);
    });
    document.addEventListener('click', function (event) {
      if (!event.target.closest('.xjh-weather-card')) hideSuggestions();
    });
    els.search.addEventListener('click', submitSearch);
    els.refresh.addEventListener('click', function () { loadWeather(activeLocation); });

    const saved = localStorage.getItem('xjhWeatherCity') || '青岛崂山区';
    resolveLocation(saved).then(loadWeather).catch(function () { loadWeather(presetList[0]); });
  }());
</script>

