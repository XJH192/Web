      refresh: document.getElementById('xjh-weather-refresh'),
      status: document.getElementById('xjh-weather-status'),
      link: document.getElementById('xjh-weather-link'),
      suggestions: document.getElementById('xjh-weather-suggestions')
    };
    const codeMap = {
      0: ['晴', '晴'], 1: ['晴间多云', '晴'], 2: ['多云', '云'], 3: ['阴', '阴'],
      45: ['有雾', '雾'], 48: ['雾凇', '雾'], 51: ['小雨', '雨'], 53: ['小雨', '雨'], 55: ['小雨', '雨'],
      61: ['小雨', '雨'], 63: ['中雨', '雨'], 65: ['大雨', '雨'], 71: ['小雪', '雪'], 73: ['中雪', '雪'], 75: ['大雪', '雪'],
      80: ['阵雨', '雨'], 81: ['阵雨', '雨'], 82: ['强阵雨', '雨'], 95: ['雷雨', '雷'], 96: ['雷雨', '雷'], 99: ['强雷雨', '雷']
    };
    let activeLocation = localLocations[0];
    let searchTimer = null;
    let currentSuggestions = [];
    let activeIndex = -1;

    function weatherLabel(code) { return codeMap[code] || ['天气变化', '天']; }
    function setStatus(text) { els.status.textContent = text; }
    function formatDate(value) {
      const date = new Date(value + 'T00:00:00+08:00');
      return new Intl.DateTimeFormat('zh-CN', { timeZone: 'Asia/Shanghai', weekday: 'short' }).format(date);
    }
    function normalize(text) {
      return String(text || '').replace(/[\s·,，。省市区县特别行政新区自治州盟地区]/g, '').toLowerCase();
    }
    function isDirectionOnly(text) {
      const key = normalize(text);
      return ['东', '南', '西', '北', '东北', '东南', '西北', '西南', '东部', '南部', '西部', '北部', '中部', '中心', '郊区', '近郊'].indexOf(key) >= 0;
    }
    function remoteResultRelevant(city, keyword) {
      const key = normalize(keyword);
      if (!key || isDirectionOnly(keyword) || isDirectionOnly(city.name)) return false;
      const provinceKey = normalize(city.admin1);
      const cityKey = normalize(city.admin2);
      const nameKey = normalize(city.name);
      const terms = [provinceKey, cityKey, nameKey].filter(function (term) { return term && !isDirectionOnly(term); });
      if (!terms.length) return false;
      if (terms.some(function (term) { return term === key || term.indexOf(key) >= 0 || (key.indexOf(term) >= 0 && term.length >= 2); })) return true;
      return terms.join('').indexOf(key) >= 0;
    }
    function compactName(item) {
      return normalize([item.province, item.city, item.district, item.name].concat(item.aliases || []).join(' '));
    }
    function scoreLocation(item, keyword) {
      const key = normalize(keyword);
      if (!key) return item.name === '青岛市崂山区' ? 100 : 1;
      const cityKey = normalize(item.city);
      const provinceKey = normalize(item.province);
      const districtKey = normalize(item.district);
      const names = [item.province, item.city, item.district, item.name, item.label].concat(item.aliases || []).filter(Boolean).map(normalize);
      let best = 0;
      names.forEach(function (name) {
        if (!name) return;
        if (name === key) best = Math.max(best, 120);
        else if (name.indexOf(key) === 0) best = Math.max(best, 94);
        else if (name.indexOf(key) >= 0) best = Math.max(best, 72);
        else if (key.indexOf(name) >= 0 && name.length >= 2) best = Math.max(best, 56);
      });
      if (key === cityKey && !districtKey) best = Math.max(best, 160);
      if (key === cityKey && districtKey) best = Math.min(Math.max(best, 82), 92);
      if (key === provinceKey && !districtKey) best = Math.max(best, 112);
      if (key === provinceKey && districtKey) best = Math.min(Math.max(best, 72), 82);
      const capitalMap = { '河北': '石家庄', '辽宁': '沈阳', '山东': '济南', '湖北': '武汉', '广东': '广州', '浙江': '杭州', '江苏': '南京', '四川': '成都', '陕西': '西安' };
      if (key === provinceKey && capitalMap[key] && cityKey === normalize(capitalMap[key]) && !districtKey) best += 28;
      if (key === districtKey) best = Math.max(best, 150);
      const all = compactName(item);
      let hit = 0;
      key.split('').forEach(function (ch) { if (all.indexOf(ch) >= 0) hit += 1; });
      if (key.length > 1 && hit === key.length) best = Math.max(best, 44 + hit);
      return best;
    }
    function uniqueLocations(items) {
      const seen = {};
      return items.filter(function (item) {
        const key = normalize(item.name + item.latitude + item.longitude);
        if (seen[key]) return false;
        seen[key] = true;
        return true;
      });
    }
    function localMatches(keyword) {
      const items = localLocations
        .map(function (item) { return Object.assign({ score: scoreLocation(item, keyword), source: '本地城市库' }, item); })
        .filter(function (item) { return !keyword || item.score > 0; })
        .sort(function (a, b) { return b.score - a.score || (a.district ? 1 : 0) - (b.district ? 1 : 0) || a.province.localeCompare(b.province, 'zh-CN') || a.name.length - b.name.length; });
      return uniqueLocations(items).slice(0, 18);
    }
    function escapeHtml(value) {
      return String(value == null ? '' : value).replace(/[&<>"']/g, function (ch) {
        return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' }[ch];
      });
    }
    function suggestionNote(keyword, items) {
      const key = normalize(keyword);
      if (!keyword || !items.length) return '';
      if ((key === '河北' || key === '辽宁' || key === '山东') && /市$/.test(keyword.trim())) {
        return '<div class="xjh-weather-note">没有“' + escapeHtml(keyword.trim()) + '”这个标准城市，已按省份展示下级城市。</div>';
      }
      if (keyword.length >= 4 && items.some(function (item) { return keyword.indexOf(item.city.replace('市', '')) >= 0; }) && items.some(function (item) { return keyword.indexOf(item.province.replace('省', '')) >= 0; })) {
        return '<div class="xjh-weather-note">检测到多个地区关键词，请从下方选择准确城市。</div>';
      }
      return '';
    }
    function renderSuggestions(items, keyword, nextIndex) {
      currentSuggestions = uniqueLocations(items).slice(0, 18);
      if (currentSuggestions.length) activeIndex = typeof nextIndex === 'number' ? Math.max(0, Math.min(nextIndex, currentSuggestions.length - 1)) : 0;
      else activeIndex = -1;
      if (!currentSuggestions.length) {
        els.suggestions.innerHTML = '<div class="xjh-weather-empty">没有匹配结果。试试输入“青岛”“崂山”“石家庄”“大连”这样的标准城市或区县名。</div>';
      } else {
        els.suggestions.innerHTML = suggestionNote(keyword, currentSuggestions) + currentSuggestions.map(function (item, index) {
          const active = index === activeIndex ? ' is-active' : '';
          const badge = item.source === '联网匹配' ? '网络' : (item.district ? '区县' : (normalize(item.province) === normalize(keyword) ? '省份' : '城市'));
          return '<button type="button" class="xjh-weather-option' + active + '" data-weather-index="' + index + '" role="option">'
            + '<span><b>' + escapeHtml(item.name) + '</b><em>' + escapeHtml(badge) + '</em></span>'
            + '<small>' + escapeHtml(item.province === item.city ? item.province : item.province + ' / ' + item.city) + (item.district ? ' / ' + escapeHtml(item.district) : '') + '</small>'
            + '</button>';
        }).join('');
      }
      els.suggestions.hidden = false;
      els.input.setAttribute('aria-expanded', 'true');
    }
    function hideSuggestions() {
      els.suggestions.hidden = true;
      els.input.setAttribute('aria-expanded', 'false');
    }
    async function remoteMatches(keyword) {
      const key = normalize(keyword);
      if (!key || key.length < 2 || isDirectionOnly(keyword)) return [];
      const url = 'https://geocoding-api.open-meteo.com/v1/search?count=20&language=zh&format=json&countryCode=CN&name=' + encodeURIComponent(keyword);
      const response = await fetch(url);
      if (!response.ok) return [];
      const data = await response.json();
      return (data.results || []).filter(function (city) {
        if (city.country_code && city.country_code !== 'CN') return false;
        return remoteResultRelevant(city, keyword);
      }).map(function (city) {
        const province = city.admin1 || '中国';
        const rawCity = city.admin2 && !isDirectionOnly(city.admin2) ? city.admin2 : city.name;
        const cityName = rawCity || province;
        const district = city.admin2 && city.name && normalize(city.admin2) !== normalize(city.name) && !isDirectionOnly(city.name) ? city.name : '';
        const displayName = district ? cityName + district : cityName;
        return {
          province: province,
          city: cityName,
          district: district,
          name: displayName,
          label: province + ' · ' + displayName,
          latitude: city.latitude,
          longitude: city.longitude,
          link: 'https://weather.cma.cn/',
          aliases: [city.name, city.admin2, city.admin1].filter(Boolean),
          source: '联网匹配',
          score: scoreLocation({ province: province, city: cityName, district: district, name: displayName, label: displayName, aliases: [city.name, city.admin2, city.admin1].filter(Boolean) }, keyword) || 36
        };
      }).sort(function (a, b) { return b.score - a.score || a.name.length - b.name.length; });
    }
    async function resolveLocation(name) {
      const locals = localMatches(name);
      if (locals.length && locals[0].score >= 45) return locals[0];
      const remote = await remoteMatches(name);
      if (remote.length) return remote[0];
      throw new Error('没有找到这个城市或区县');
    }
    async function updateSuggestions(keyword) {
      const locals = localMatches(keyword);
      renderSuggestions(locals, keyword);
      if (!keyword || keyword.trim().length < 2 || (locals[0] && locals[0].score >= 75)) return;
      try {
        const remotes = await remoteMatches(keyword.trim());
        renderSuggestions(locals.concat(remotes), keyword);
      } catch (error) {}
    }
    function hasCoordinates(location) {
      return location && Number.isFinite(Number(location.latitude)) && Number.isFinite(Number(location.longitude));
    }
    async function ensureCoordinates(location) {
      if (hasCoordinates(location)) return location;
      const query = location && (location.district || location.city || location.name);
      const remote = await remoteMatches(query || '');
      const exact = remote.find(function (item) {
        return normalize(item.name) === normalize(location.name) || normalize(item.city) === normalize(location.city);
      }) || remote[0];
      if (exact) {
        return Object.assign({}, location, exact, { name: location.name, label: location.label || exact.label, source: location.source || exact.source });
      }
      throw new Error('没有找到这个城市的坐标，请换一个更具体的城市或区县名称');
    }
    async function loadWeather(location) {
      location = await ensureCoordinates(location);
      activeLocation = location;
      els.city.textContent = location.name;
      els.input.value = location.name;
      els.link.href = location.link || 'https://weather.cma.cn/';
      els.desc.textContent = '正在更新';
      els.detail.textContent = '读取实时天气...';
      setStatus('正在连接天气服务...');
      hideSuggestions();
      const params = new URLSearchParams({
        latitude: location.latitude,
        longitude: location.longitude,
        current: 'temperature_2m,relative_humidity_2m,apparent_temperature,weather_code,wind_speed_10m',
        daily: 'weather_code,temperature_2m_max,temperature_2m_min',
        timezone: 'Asia/Shanghai',
        forecast_days: '2'
      });
      const response = await fetch('https://api.open-meteo.com/v1/forecast?' + params.toString());
      if (!response.ok) throw new Error('天气服务暂不可用');
      const data = await response.json();
      const current = data.current || {};
      const label = weatherLabel(current.weather_code);
      els.icon.textContent = label[1];
      els.temp.textContent = Math.round(current.temperature_2m) + '°';
      els.detail.textContent = label[0] + ' · ' + (current.time || '').replace('T', ' ');
      els.feels.textContent = '体感 ' + Math.round(current.apparent_temperature) + '°';
      els.humidity.textContent = '湿度 ' + Math.round(current.relative_humidity_2m) + '%';
      els.wind.textContent = '风速 ' + Math.round(current.wind_speed_10m) + 'km/h';
      els.desc.textContent = '实时天气';
      els.forecast.innerHTML = (data.daily && data.daily.time ? data.daily.time : []).map(function (day, index) {
        const text = weatherLabel(data.daily.weather_code[index])[0];
        return '<span><b>' + formatDate(day) + '</b>' + text + ' ' + Math.round(data.daily.temperature_2m_min[index]) + '°/' + Math.round(data.daily.temperature_2m_max[index]) + '°</span>';
      }).join('');
      localStorage.setItem('xjhWeatherCity', location.name);
      setStatus('已按北京时间更新');
    }
    async function submitSearch() {
      const keyword = els.input.value.trim() || '青岛崂山区';
      try {
        const selected = !els.suggestions.hidden && currentSuggestions[activeIndex] ? currentSuggestions[activeIndex] : null;
        const location = selected || await resolveLocation(keyword);
        await loadWeather(location);
      } catch (error) {
        els.desc.textContent = '天气异常';
        els.detail.textContent = error.message;
        setStatus('可以换一个城市或区县名称再试。');
      }
    }
    function moveActive(delta) {
      if (!currentSuggestions.length) return;
      const nextIndex = (activeIndex + delta + currentSuggestions.length) % currentSuggestions.length;
      renderSuggestions(currentSuggestions, els.input.value, nextIndex);
    }

    els.input.addEventListener('focus', function () { updateSuggestions(els.input.value); });
    els.input.addEventListener('input', function () {
      clearTimeout(searchTimer);
      renderSuggestions(localMatches(els.input.value), els.input.value);
      searchTimer = setTimeout(function () { updateSuggestions(els.input.value); }, 160);
    });
    els.input.addEventListener('keydown', function (event) {
      if (event.key === 'ArrowDown') { event.preventDefault(); moveActive(1); }
      if (event.key === 'ArrowUp') { event.preventDefault(); moveActive(-1); }
      if (event.key === 'Enter') { event.preventDefault(); submitSearch(); }
      if (event.key === 'Escape') hideSuggestions();
    });
    els.suggestions.addEventListener('mousedown', function (event) {
      const option = event.target.closest('[data-weather-index]');
      if (!option) return;
      event.preventDefault();
      const location = currentSuggestions[Number(option.getAttribute('data-weather-index'))];
      if (location) loadWeather(location);
    });
    document.addEventListener('click', function (event) {
      if (!event.target.closest('.xjh-weather-card')) hideSuggestions();
    });
    els.search.addEventListener('click', submitSearch);
    els.refresh.addEventListener('click', function () { loadWeather(activeLocation); });

    const saved = localStorage.getItem('xjhWeatherCity') || '青岛崂山区';
    resolveLocation(saved).then(loadWeather).catch(function () { loadWeather(localLocations[0]); });
  }());
</script>

