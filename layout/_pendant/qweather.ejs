    flex: 0 0 auto;
  }
  .xjh-weather-main b { display: block; color: #2b211d; font-size: 26px; line-height: 1; }
  .xjh-weather-main span { color: #5d4a40; font-size: 12px; line-height: 1.5; }
  .xjh-weather-meta { flex-wrap: wrap; gap: 5px; }
  .xjh-weather-meta span,
  .xjh-weather-forecast span {
    border-radius: 999px;
    padding: 4px 7px;
    background: rgba(230, 114, 73, .1);
    color: #63483b;
    font-size: 12px;
    line-height: 1.2;
  }
  .xjh-weather-forecast { flex-wrap: wrap; gap: 5px; margin-top: 8px; }
