    display: inline-flex;
    align-items: center;
    justify-content: center;
    font: inherit;
    font-size: 13px;
    font-weight: 750;
    text-decoration: none;
    white-space: nowrap;
  }
  .xjh-weather-link { background: rgba(230, 114, 73, .12); color: #c95531; }
  .xjh-weather-source { margin: 8px 0 0; line-height: 1.5; }
  .xjh-weather-suggestions {
    position: absolute;
    left: 0;
    right: 48px;
    top: calc(100% + 6px);
    z-index: 60;
