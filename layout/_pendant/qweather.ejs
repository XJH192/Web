<div class="nexmoe-pd-item xjh-weather-wrap">
  <section class="xjh-weather-card" aria-label="实时天气">
    <div class="xjh-weather-head">
      <div>
        <strong id="xjh-weather-city">青岛崂山区</strong>
        <span id="xjh-weather-desc">实时天气</span>
      </div>
      <button id="xjh-weather-refresh" type="button" aria-label="刷新天气">↻</button>
    </div>
    <div class="xjh-weather-main">
      <div class="xjh-weather-icon" id="xjh-weather-icon">待</div>
      <div>
        <b id="xjh-weather-temp">待更新</b>
        <span id="xjh-weather-detail">正在获取天气...</span>
      </div>
    </div>
    <div class="xjh-weather-meta">
      <span id="xjh-weather-feels">体感待更新</span>
      <span id="xjh-weather-humidity">湿度待更新</span>
      <span id="xjh-weather-wind">风速待更新</span>
    </div>
    <div class="xjh-weather-forecast" id="xjh-weather-forecast"></div>
    <div class="xjh-weather-controls">
      <div class="xjh-weather-search" id="xjh-weather-searchbox">
        <input id="xjh-weather-input" type="search" autocomplete="off" role="combobox" aria-expanded="false" aria-controls="xjh-weather-suggestions" placeholder="输入城市或区县">
        <button id="xjh-weather-search-btn" type="button">查询</button>
        <div id="xjh-weather-suggestions" class="xjh-weather-suggestions" role="listbox" hidden></div>
      </div>
      <a id="xjh-weather-link" class="xjh-weather-link" href="https://weather.cma.cn/web/weather/54857.html" target="_blank" rel="noopener">打开天气网站</a>
    </div>
    <p class="xjh-weather-source" id="xjh-weather-status">数据源 Open-Meteo，按北京时间更新。</p>
  </section>
</div>

<script>
  (function () {
    const localLocations = [
      ['山东省', '青岛市', '崂山区', 36.107, 120.468, 'https://weather.cma.cn/web/weather/54857.html', ['青岛崂山', '崂山', 'laoshan']],
      ['山东省', '青岛市', '市南区', 36.066, 120.382, 'https://weather.cma.cn/web/weather/54857.html', ['市南', '青岛市南']],
      ['山东省', '青岛市', '市北区', 36.087, 120.374, 'https://weather.cma.cn/web/weather/54857.html', ['市北', '青岛市北']],
      ['山东省', '青岛市', '李沧区', 36.145, 120.432, 'https://weather.cma.cn/web/weather/54857.html', ['李沧', '青岛李沧']],
      ['山东省', '青岛市', '', 36.067, 120.383, 'https://weather.cma.cn/web/weather/54857.html', ['青岛', 'qingdao']],
      ['山东省', '济南市', '', 36.651, 117.120, 'https://weather.cma.cn/', ['济南', 'jinan']],
      ['山东省', '烟台市', '', 37.464, 121.447, 'https://weather.cma.cn/', ['烟台']],
      ['山东省', '潍坊市', '', 36.707, 119.162, 'https://weather.cma.cn/', ['潍坊']],
      ['山东省', '威海市', '', 37.514, 122.120, 'https://weather.cma.cn/', ['威海']],
      ['山东省', '临沂市', '', 35.104, 118.356, 'https://weather.cma.cn/', ['临沂']],
      ['北京市', '北京市', '', 39.904, 116.407, 'https://weather.cma.cn/web/weather/54511.html', ['北京', 'beijing']],
      ['北京市', '北京市', '海淀区', 39.960, 116.298, 'https://weather.cma.cn/web/weather/54399.html', ['海淀', '北京海淀']],
      ['北京市', '北京市', '朝阳区', 39.921, 116.443, 'https://weather.cma.cn/web/weather/54433.html', ['朝阳', '北京朝阳']],
      ['上海市', '上海市', '', 31.231, 121.474, 'https://weather.cma.cn/web/weather/58362.html', ['上海', 'shanghai']],
      ['广东省', '广州市', '天河区', 23.135, 113.361, 'https://weather.cma.cn/web/weather/59287.html', ['广州', '天河', '广州天河']],
      ['广东省', '深圳市', '南山区', 22.533, 113.930, 'https://weather.cma.cn/web/weather/59493.html', ['深圳', '南山', '深圳南山']],
      ['浙江省', '杭州市', '西湖区', 30.259, 120.130, 'https://weather.cma.cn/web/weather/58457.html', ['杭州', '西湖', '杭州西湖']],
      ['江苏省', '南京市', '鼓楼区', 32.067, 118.769, 'https://weather.cma.cn/web/weather/58238.html', ['南京', '鼓楼', '南京鼓楼']],
      ['四川省', '成都市', '武侯区', 30.642, 104.043, 'https://weather.cma.cn/web/weather/56294.html', ['成都', '武侯', '成都武侯']],
      ['陕西省', '西安市', '雁塔区', 34.213, 108.948, 'https://weather.cma.cn/web/weather/57036.html', ['西安', '雁塔', '西安雁塔']],
      ['湖北省', '武汉市', '洪山区', 30.500, 114.343, 'https://weather.cma.cn/web/weather/57494.html', ['武汉', '洪山', '武汉洪山']],
      ['河北省', '石家庄市', '', 38.042, 114.514, 'https://weather.cma.cn/', ['河北', '石家庄', 'sjz']],
      ['河北省', '石家庄市', '长安区', 38.050, 114.539, 'https://weather.cma.cn/', ['长安', '石家庄长安']],
      ['河北省', '唐山市', '', 39.630, 118.180, 'https://weather.cma.cn/', ['唐山']],
      ['河北省', '秦皇岛市', '', 39.935, 119.600, 'https://weather.cma.cn/', ['秦皇岛']],
      ['河北省', '邯郸市', '', 36.625, 114.539, 'https://weather.cma.cn/', ['邯郸']],
      ['河北省', '邢台市', '', 37.070, 114.504, 'https://weather.cma.cn/', ['邢台']],
      ['河北省', '保定市', '', 38.873, 115.464, 'https://weather.cma.cn/', ['保定']],
      ['河北省', '张家口市', '', 40.824, 114.887, 'https://weather.cma.cn/', ['张家口']],
      ['河北省', '承德市', '', 40.954, 117.962, 'https://weather.cma.cn/', ['承德']],
      ['河北省', '沧州市', '', 38.304, 116.838, 'https://weather.cma.cn/', ['沧州']],
      ['河北省', '廊坊市', '', 39.538, 116.683, 'https://weather.cma.cn/', ['廊坊']],
      ['河北省', '衡水市', '', 37.739, 115.669, 'https://weather.cma.cn/', ['衡水']],
      ['河北省', '雄安新区', '', 38.990, 115.892, 'https://weather.cma.cn/', ['雄安', '容城', '安新', '雄县']],
      ['辽宁省', '沈阳市', '', 41.805, 123.431, 'https://weather.cma.cn/', ['辽宁', '沈阳', 'shenyang']],
      ['辽宁省', '大连市', '', 38.914, 121.614, 'https://weather.cma.cn/', ['大连']],
      ['辽宁省', '鞍山市', '', 41.108, 122.995, 'https://weather.cma.cn/', ['鞍山']],
      ['辽宁省', '抚顺市', '', 41.881, 123.957, 'https://weather.cma.cn/', ['抚顺']],
      ['辽宁省', '本溪市', '', 41.294, 123.766, 'https://weather.cma.cn/', ['本溪']],
      ['辽宁省', '丹东市', '', 40.129, 124.354, 'https://weather.cma.cn/', ['丹东']],
      ['辽宁省', '锦州市', '', 41.095, 121.127, 'https://weather.cma.cn/', ['锦州']],
      ['辽宁省', '营口市', '', 40.667, 122.235, 'https://weather.cma.cn/', ['营口']],
      ['辽宁省', '辽阳市', '', 41.269, 123.172, 'https://weather.cma.cn/', ['辽阳']],
      ['辽宁省', '盘锦市', '', 41.120, 122.070, 'https://weather.cma.cn/', ['盘锦']],
      ['辽宁省', '铁岭市', '', 42.286, 123.842, 'https://weather.cma.cn/', ['铁岭']],
      ['辽宁省', '朝阳市', '', 41.574, 120.450, 'https://weather.cma.cn/', ['朝阳', '辽宁朝阳']],
      ['辽宁省', '葫芦岛市', '', 40.711, 120.837, 'https://weather.cma.cn/', ['葫芦岛']]
    ].map(function (row) {
      const province = row[0], city = row[1], district = row[2];
      const name = district ? city + district : city;
      const label = province === city ? name : province + ' · ' + name;
      return {
        province: province,
        city: city,
        district: district,
        name: name,
        label: label,
        latitude: row[3],
        longitude: row[4],
        link: row[5],
        aliases: row[6]
      };
    });

    const els = {
      city: document.getElementById('xjh-weather-city'),
      desc: document.getElementById('xjh-weather-desc'),
      icon: document.getElementById('xjh-weather-icon'),
      temp: document.getElementById('xjh-weather-temp'),
      detail: document.getElementById('xjh-weather-detail'),
      feels: document.getElementById('xjh-weather-feels'),
      humidity: document.getElementById('xjh-weather-humidity'),
      wind: document.getElementById('xjh-weather-wind'),
      forecast: document.getElementById('xjh-weather-forecast'),
      input: document.getElementById('xjh-weather-input'),
      search: document.getElementById('xjh-weather-search-btn'),
      refresh: document.getElementById('xjh-weather-refresh'),
      status: document.getElementById('xjh-weather-status'),
      link: document.getElementById('xjh-weather-link'),
      suggestions: document.getElementById('xjh-weather-suggestions')
    };
    const codeMap = {
      0: ['晴', '晴'], 1: ['晴间多云', '晴'], 2: ['多云', '云'], 3: ['阴', '阴'],
      45: ['有雾', '雾'], 48: ['雾凇', '雾'], 51: ['小雨', '雨'], 53: ['小雨', '雨'], 55: ['小雨', '雨'],
      61: ['小雨', '雨'], 63: ['中雨', '雨'], 65: ['大雨', '雨'], 71: ['小雪', '雪'], 73: ['中雪', '雪'], 75: ['大雪', '雪'],
      80: ['阵雨', '雨'], 81: ['阵雨', '雨'], 82: ['强阵雨', '雨'], 95: ['雷雨', '雷'], 96: ['雷雨', '雷'], 99: ['强雷雨', '雷']
    };
    let activeLocation = localLocations[0];
    let searchTimer = null;
    let currentSuggestions = [];
    let activeIndex = -1;

    function weatherLabel(code) { return codeMap[code] || ['天气变化', '天']; }
    function setStatus(text) { els.status.textContent = text; }
    function formatDate(value) {
      const date = new Date(value + 'T00:00:00+08:00');
      return new Intl.DateTimeFormat('zh-CN', { timeZone: 'Asia/Shanghai', weekday: 'short' }).format(date);
    }
    function normalize(text) {
      return String(text || '').replace(/[\s·,，。省市区县特别行政新区自治州盟地区]/g, '').toLowerCase();
    }
    function compactName(item) {
      return normalize([item.province, item.city, item.district, item.name].concat(item.aliases || []).join(' '));
    }
    function scoreLocation(item, keyword) {
      const key = normalize(keyword);
      if (!key) return item.name === '青岛市崂山区' ? 100 : 1;
      const names = [item.province, item.city, item.district, item.name, item.label].concat(item.aliases || []).filter(Boolean).map(normalize);
      let best = 0;
      names.forEach(function (name) {
        if (!name) return;
        if (name === key) best = Math.max(best, 120);
        else if (name.indexOf(key) === 0) best = Math.max(best, 95);
        else if (name.indexOf(key) >= 0) best = Math.max(best, 75);
        else if (key.indexOf(name) >= 0 && name.length >= 2) best = Math.max(best, 58);
      });
      if (normalize(item.province) === key) best = Math.max(best, 86);
      if (keyword.indexOf('市') >= 0 && normalize(keyword).length <= 3 && normalize(item.province) === key) best = Math.max(best, 84);
      const all = compactName(item);
      let hit = 0;
      key.split('').forEach(function (ch) { if (all.indexOf(ch) >= 0) hit += 1; });
      if (key.length > 1 && hit === key.length) best = Math.max(best, 45 + hit);
      return best;
    }
    function uniqueLocations(items) {
      const seen = {};
      return items.filter(function (item) {
        const key = normalize(item.name + item.latitude + item.longitude);
        if (seen[key]) return false;
        seen[key] = true;
        return true;
      });
    }
    function localMatches(keyword) {
      const items = localLocations
        .map(function (item) { return Object.assign({ score: scoreLocation(item, keyword), source: '本地城市库' }, item); })
        .filter(function (item) { return !keyword || item.score > 0; })
        .sort(function (a, b) { return b.score - a.score || a.province.localeCompare(b.province, 'zh-CN') || a.name.length - b.name.length; });
      return uniqueLocations(items).slice(0, 10);
    }
    function escapeHtml(value) {
      return String(value == null ? '' : value).replace(/[&<>"']/g, function (ch) {
        return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' }[ch];
      });
    }
    function suggestionNote(keyword, items) {
      const key = normalize(keyword);
      if (!keyword || !items.length) return '';
      if ((key === '河北' || key === '辽宁' || key === '山东') && /市$/.test(keyword.trim())) {
        return '<div class="xjh-weather-note">没有“' + escapeHtml(keyword.trim()) + '”这个标准城市，已按省份展示下级城市。</div>';
      }
      if (keyword.length >= 4 && items.some(function (item) { return keyword.indexOf(item.city.replace('市', '')) >= 0; }) && items.some(function (item) { return keyword.indexOf(item.province.replace('省', '')) >= 0; })) {
        return '<div class="xjh-weather-note">检测到多个地区关键词，请从下方选择准确城市。</div>';
      }
      return '';
    }
    function renderSuggestions(items, keyword, nextIndex) {
      currentSuggestions = uniqueLocations(items).slice(0, 8);
      if (currentSuggestions.length) activeIndex = typeof nextIndex === 'number' ? Math.max(0, Math.min(nextIndex, currentSuggestions.length - 1)) : 0;
      else activeIndex = -1;
      if (!currentSuggestions.length) {
        els.suggestions.innerHTML = '<div class="xjh-weather-empty">没有匹配结果。试试输入“青岛”“河北”“石家庄”“大连”这样的城市或区县名。</div>';
      } else {
        els.suggestions.innerHTML = suggestionNote(keyword, currentSuggestions) + currentSuggestions.map(function (item, index) {
          const active = index === activeIndex ? ' is-active' : '';
          const badge = item.source === '联网匹配' ? '联网' : (normalize(item.province) === normalize(keyword) ? '省份' : '推荐');
          return '<button type="button" class="xjh-weather-option' + active + '" data-weather-index="' + index + '" role="option">'
            + '<span><b>' + escapeHtml(item.name) + '</b><em>' + escapeHtml(badge) + '</em></span>'
            + '<small>' + escapeHtml(item.province === item.city ? item.province : item.province + ' / ' + item.city) + (item.district ? ' / ' + escapeHtml(item.district) : '') + '</small>'
            + '</button>';
        }).join('');
      }
      els.suggestions.hidden = false;
      els.input.setAttribute('aria-expanded', 'true');
    }
    function hideSuggestions() {
      els.suggestions.hidden = true;
      els.input.setAttribute('aria-expanded', 'false');
    }
    async function remoteMatches(keyword) {
      const key = normalize(keyword);
      if (!key || key.length < 2) return [];
      const url = 'https://geocoding-api.open-meteo.com/v1/search?count=8&language=zh&format=json&countryCode=CN&name=' + encodeURIComponent(keyword);
      const response = await fetch(url);
      if (!response.ok) return [];
      const data = await response.json();
      return (data.results || []).filter(function (city) {
        if (city.country_code && city.country_code !== 'CN') return false;
        const label = [city.admin1, city.admin2, city.name].filter(Boolean).join('');
        const normalized = normalize(label);
        return normalized.indexOf(key) >= 0 || key.indexOf(normalize(city.name)) >= 0;
      }).map(function (city) {
        const province = city.admin1 || '中国';
        const cityName = city.name || province;
        return {
          province: province,
          city: city.admin2 || cityName,
          district: '',
          name: cityName,
          label: province + ' · ' + cityName,
          latitude: city.latitude,
          longitude: city.longitude,
          link: 'https://weather.cma.cn/',
          aliases: [],
          source: '联网匹配',
          score: 30
        };
      });
    }
    async function resolveLocation(name) {
      const locals = localMatches(name);
      if (locals.length && locals[0].score >= 45) return locals[0];
      const remote = await remoteMatches(name);
      if (remote.length) return remote[0];
      throw new Error('没有找到这个城市或区县');
    }
    async function updateSuggestions(keyword) {
      const locals = localMatches(keyword);
      renderSuggestions(locals, keyword);
      if (!keyword || keyword.trim().length < 3 || (locals[0] && locals[0].score >= 75)) return;
      try {
        const remotes = await remoteMatches(keyword.trim());
        renderSuggestions(locals.concat(remotes), keyword);
      } catch (error) {}
    }
    async function loadWeather(location) {
      activeLocation = location;
      els.city.textContent = location.name;
      els.input.value = location.name;
      els.link.href = location.link || 'https://weather.cma.cn/';
      els.desc.textContent = '正在更新';
      els.detail.textContent = '读取实时天气...';
      setStatus('正在连接天气服务...');
      hideSuggestions();
      const params = new URLSearchParams({
        latitude: location.latitude,
        longitude: location.longitude,
        current: 'temperature_2m,relative_humidity_2m,apparent_temperature,weather_code,wind_speed_10m',
        daily: 'weather_code,temperature_2m_max,temperature_2m_min',
        timezone: 'Asia/Shanghai',
        forecast_days: '2'
      });
      const response = await fetch('https://api.open-meteo.com/v1/forecast?' + params.toString());
      if (!response.ok) throw new Error('天气服务暂不可用');
      const data = await response.json();
      const current = data.current || {};
      const label = weatherLabel(current.weather_code);
      els.icon.textContent = label[1];
      els.temp.textContent = Math.round(current.temperature_2m) + '°';
      els.detail.textContent = label[0] + ' · ' + (current.time || '').replace('T', ' ');
      els.feels.textContent = '体感 ' + Math.round(current.apparent_temperature) + '°';
      els.humidity.textContent = '湿度 ' + Math.round(current.relative_humidity_2m) + '%';
      els.wind.textContent = '风速 ' + Math.round(current.wind_speed_10m) + 'km/h';
      els.desc.textContent = '实时天气';
      els.forecast.innerHTML = (data.daily && data.daily.time ? data.daily.time : []).map(function (day, index) {
        const text = weatherLabel(data.daily.weather_code[index])[0];
        return '<span><b>' + formatDate(day) + '</b>' + text + ' ' + Math.round(data.daily.temperature_2m_min[index]) + '°/' + Math.round(data.daily.temperature_2m_max[index]) + '°</span>';
      }).join('');
      localStorage.setItem('xjhWeatherCity', location.name);
      setStatus('已按北京时间更新');
    }
    async function submitSearch() {
      const keyword = els.input.value.trim() || '青岛崂山区';
      try {
        const selected = !els.suggestions.hidden && currentSuggestions[activeIndex] ? currentSuggestions[activeIndex] : null;
        const location = selected || await resolveLocation(keyword);
        await loadWeather(location);
      } catch (error) {
        els.desc.textContent = '天气异常';
        els.detail.textContent = error.message;
        setStatus('可以换一个城市或区县名称再试。');
      }
    }
    function moveActive(delta) {
      if (!currentSuggestions.length) return;
      const nextIndex = (activeIndex + delta + currentSuggestions.length) % currentSuggestions.length;
      renderSuggestions(currentSuggestions, els.input.value, nextIndex);
    }

    els.input.addEventListener('focus', function () { updateSuggestions(els.input.value); });
    els.input.addEventListener('input', function () {
      clearTimeout(searchTimer);
      renderSuggestions(localMatches(els.input.value), els.input.value);
      searchTimer = setTimeout(function () { updateSuggestions(els.input.value); }, 160);
    });
    els.input.addEventListener('keydown', function (event) {
      if (event.key === 'ArrowDown') { event.preventDefault(); moveActive(1); }
      if (event.key === 'ArrowUp') { event.preventDefault(); moveActive(-1); }
      if (event.key === 'Enter') { event.preventDefault(); submitSearch(); }
      if (event.key === 'Escape') hideSuggestions();
    });
    els.suggestions.addEventListener('mousedown', function (event) {
      const option = event.target.closest('[data-weather-index]');
      if (!option) return;
      event.preventDefault();
      const location = currentSuggestions[Number(option.getAttribute('data-weather-index'))];
      if (location) loadWeather(location);
    });
    document.addEventListener('click', function (event) {
      if (!event.target.closest('.xjh-weather-card')) hideSuggestions();
    });
    els.search.addEventListener('click', submitSearch);
    els.refresh.addEventListener('click', function () { loadWeather(activeLocation); });

    const saved = localStorage.getItem('xjhWeatherCity') || '青岛崂山区';
    resolveLocation(saved).then(loadWeather).catch(function () { loadWeather(localLocations[0]); });
  }());
</script>

<style>
  .xjh-weather-wrap { justify-content: flex-end; }
  .xjh-weather-card {
    width: 260px;
    border: 1px solid rgba(230, 114, 73, .22);
    border-radius: 12px;
    padding: 12px;
    background: rgba(255, 250, 246, .95);
    color: #30231d;
    box-shadow: 0 2px 8px rgba(87, 48, 31, .14);
  }
  .xjh-weather-head,
  .xjh-weather-main,
  .xjh-weather-meta,
  .xjh-weather-controls,
  .xjh-weather-search,
  .xjh-weather-forecast {
    display: flex;
    align-items: center;
  }
  .xjh-weather-head { justify-content: space-between; gap: 8px; }
  .xjh-weather-head strong { display: block; color: #2b211d; font-size: 14px; }
