<div class="nexmoe-pd-item ciallo-clock-wrap">
  <section class="ciallo-clock-card" aria-label="北京时间">
    <div class="ciallo-clock" data-ciallo-clock>
      <% for (let i = 0; i < 60; i++) { %>
        <span class="ciallo-clock-tick <% if (i % 5 === 0) { %>major<% } %>" style="--tick:<%= i %>"></span>
      <% } %>
      <span class="ciallo-clock-hand hour" data-hand="hour"></span>
      <span class="ciallo-clock-hand minute" data-hand="minute"></span>
      <span class="ciallo-clock-hand second" data-hand="second"></span>
      <span class="ciallo-clock-center"></span>
    </div>
    <div class="ciallo-clock-copy">
      <strong>北京时间</strong>
      <span data-clock-time>校准中</span>
      <small data-clock-date>正在校准</small>
    </div>
  </section>
</div>

<script>
  (function () {
    const formatter = new Intl.DateTimeFormat('zh-CN', {
      timeZone: 'Asia/Shanghai',
      hourCycle: 'h23',
      year: 'numeric', month: '2-digit', day: '2-digit',
      weekday: 'short', hour: '2-digit', minute: '2-digit', second: '2-digit'
    });
    function partsToObject(date) {
      return formatter.formatToParts(date).reduce(function (acc, part) {
        if (part.type !== 'literal') acc[part.type] = part.value;
        return acc;
      }, {});
    }
    function updateClock() {
      const box = document.querySelector('[data-ciallo-clock]');
      if (!box) return;
      const parts = partsToObject(new Date());
      const hour = Number(parts.hour);
      const minute = Number(parts.minute);
      const second = Number(parts.second);
      const hourDeg = ((hour % 12) + minute / 60 + second / 3600) * 30;
      const minuteDeg = (minute + second / 60) * 6;
      const secondDeg = second * 6;
      box.querySelector('[data-hand="hour"]').style.transform = 'translate(-50%, -100%) rotate(' + hourDeg + 'deg)';
      box.querySelector('[data-hand="minute"]').style.transform = 'translate(-50%, -100%) rotate(' + minuteDeg + 'deg)';
      box.querySelector('[data-hand="second"]').style.transform = 'translate(-50%, -100%) rotate(' + secondDeg + 'deg)';
      const timeEl = document.querySelector('[data-clock-time]');
      const dateEl = document.querySelector('[data-clock-date]');
      if (timeEl) timeEl.textContent = parts.hour + ':' + parts.minute + ':' + parts.second;
      if (dateEl) dateEl.textContent = parts.year + '-' + parts.month + '-' + parts.day + ' ' + parts.weekday;
    }
    updateClock();
    setInterval(updateClock, 1000);
  }());
</script>

<style>
  .ciallo-clock-wrap { justify-content: flex-end; }
  .ciallo-clock-card {
    width: 260px;
    display: flex;
    align-items: center;
    gap: 10px;
    border: 1px solid rgba(230, 114, 73, .22);
    border-radius: 12px;
    padding: 12px;
    background: rgba(255, 250, 246, .94);
    color: #30231d;
    box-shadow: 0 2px 8px rgba(87, 48, 31, .14);
  }
  .ciallo-clock {
    position: relative;
    flex: 0 0 78px;
    width: 78px;
    height: 78px;
    border: 4px solid #ed7c54;
    border-radius: 50%;
    background: radial-gradient(circle at 50% 50%, #fff 0 58%, #fff7f1 59% 100%);
    box-shadow: inset 0 0 0 1px rgba(230, 114, 73, .16);
  }
  .ciallo-clock-tick {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 1px;
    height: 5px;
    border-radius: 999px;
    background: #d9a08a;
    transform: translate(-50%, -50%) rotate(calc(var(--tick) * 6deg)) translateY(-31px);
    transform-origin: 50% 50%;
  }
  .ciallo-clock-tick.major {
    width: 2px;
    height: 9px;
    background: #e67249;
    transform: translate(-50%, -50%) rotate(calc(var(--tick) * 6deg)) translateY(-30px);
  }
  .ciallo-clock-hand {
    position: absolute;
    left: 50%;
    top: 50%;
    border-radius: 999px;
    transform-origin: 50% 100%;
    transition: transform .18s ease-out;
  }
  .ciallo-clock-hand.hour { width: 5px; height: 21px; background: #2f241f; }
  .ciallo-clock-hand.minute { width: 3px; height: 29px; background: #2f241f; }
  .ciallo-clock-hand.second { width: 2px; height: 32px; background: #e67249; }
  .ciallo-clock-center {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 10px;
    height: 10px;
    border: 2px solid #fff;
    border-radius: 50%;
    background: #e67249;
    transform: translate(-50%, -50%);
  }
  .ciallo-clock-copy { display: grid; gap: 4px; min-width: 0; }
  .ciallo-clock-copy strong { color: #2f241f; font-size: 15px; }
  .ciallo-clock-copy span { color: #e67249; font-size: 21px; font-weight: 800; line-height: 1; letter-spacing: .02em; }
  .ciallo-clock-copy small { color: #70594d; font-size: 12px; line-height: 1.5; }
  @media (prefers-reduced-motion: reduce) {
    .ciallo-clock-hand { transition: none; }
  }
</style>