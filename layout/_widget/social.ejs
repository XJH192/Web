<div class="nexmoe-widget-wrap">
  <div class="nexmoe-widget nexmoe-social">
    <% for (name in options.social) { const href = options.social[name][0]; const isMail = String(href).indexOf('mailto:') === 0; %><a
      class="mdui-ripple <%= isMail ? 'ciallo-mail-link' : '' %>"
      href="<%- url_for(href) -%>"
      target="<%= isMail ? '_self' : '_blank' %>"
      data-email="<%= isMail ? String(href).replace('mailto:', '') : '' %>"
      mdui-tooltip="{content: '<%= name %>'}"
      style="
        color: <%= options.social[name][2] %>;
        background-color: <%= options.social[name][3] %>;
      "
    >
      <i class="nexmoefont <% if (options.social[name][1]){ %><%= options.social[name][1] %><%} else{ %><%= 'icon-unorderedlist' %><% } %>"></i>
    </a><% } %>
  </div>
</div>
<div id="ciallo-email-modal" class="ciallo-email-modal" aria-hidden="true">
  <div class="ciallo-email-dialog" role="dialog" aria-modal="true" aria-labelledby="ciallo-email-title">
    <button type="button" class="ciallo-email-close" aria-label="关闭邮箱弹窗">×</button>
    <span class="ciallo-email-label">邮箱联系</span>
    <h3 id="ciallo-email-title">我的邮箱</h3>
    <p>复制或记录下面的邮箱即可联系我。</p>
    <strong id="ciallo-email-value">706972112@qq.com</strong>
    <div class="ciallo-email-actions">
      <button type="button" id="ciallo-email-copy">复制邮箱</button>
      <a id="ciallo-email-open" href="mailto:706972112@qq.com">打开邮件</a>
    </div>
  </div>
</div>
<script>
  (function () {
    const modal = document.getElementById('ciallo-email-modal');
    if (!modal) return;
    if (modal.parentNode !== document.body) document.body.appendChild(modal);
    const value = document.getElementById('ciallo-email-value');
    const copy = document.getElementById('ciallo-email-copy');
    const open = document.getElementById('ciallo-email-open');
    const close = modal.querySelector('.ciallo-email-close');
    let lastFocus = null;

    function show(email) {
      lastFocus = document.activeElement;
      const finalEmail = email || '706972112@qq.com';
      value.textContent = finalEmail;
      open.href = 'mailto:' + finalEmail;
      modal.classList.add('is-visible');
      modal.setAttribute('aria-hidden', 'false');
      document.body.classList.add('ciallo-email-open');
      document.body.style.overflow = 'hidden';
      close.focus();
    }
    function hide() {
      modal.classList.remove('is-visible');
      modal.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('ciallo-email-open');
      document.body.style.overflow = '';
      if (lastFocus && lastFocus.focus) lastFocus.focus();
    }

    document.addEventListener('click', function (event) {
      const link = event.target.closest('.ciallo-mail-link');
      if (link) {
        event.preventDefault();
        show(link.getAttribute('data-email'));
        return;
      }
      if (event.target === modal || event.target.closest('.ciallo-email-close')) hide();
    });
    document.addEventListener('keydown', function (event) {
      if (event.key === 'Escape' && modal.classList.contains('is-visible')) hide();
    });
    if (copy) {
      copy.addEventListener('click', function () {
        const email = value.textContent;
        if (navigator.clipboard) navigator.clipboard.writeText(email);
        copy.textContent = '已复制';
        setTimeout(function () { copy.textContent = '复制邮箱'; }, 1400);
      });
    }
  }());
</script>
<style>
  .ciallo-email-modal {
    position: fixed;
    inset: 0;
    z-index: 1200;
    display: grid;
    place-items: center;
    padding: 20px;
    background: rgba(47, 36, 31, .38);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    opacity: 0;
    visibility: hidden;
    transition: opacity .18s ease, visibility .18s ease;
  }
  .ciallo-email-modal.is-visible { opacity: 1; visibility: visible; }
  .ciallo-email-dialog {
    position: relative;
    width: min(380px, calc(100vw - 32px));
    border: 1px solid rgba(230, 114, 73, .24);
    border-radius: 14px;
    padding: 24px;
    background: rgba(255, 250, 246, .98);
    color: #2f241f;
    box-shadow: 0 8px 24px rgba(47, 36, 31, .18);
    transform: translateY(10px) scale(.98);
    transition: transform .18s ease;
  }
  .ciallo-email-modal.is-visible .ciallo-email-dialog { transform: translateY(0) scale(1); }
  .ciallo-email-close {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 32px;
    height: 32px;
    border: 0;
    border-radius: 9px;
    background: rgba(230, 114, 73, .12);
    color: #c95531;
    cursor: pointer;
    font-size: 21px;
    line-height: 1;
  }
  .ciallo-email-close:hover { background: rgba(230, 114, 73, .18); }
  .ciallo-email-label {
    display: inline-flex;
    margin-bottom: 8px;
    border-radius: 999px;
    padding: 4px 9px;
    background: rgba(230, 114, 73, .12);
    color: #c95531;
    font-size: 12px;
    font-weight: 750;
  }
  .ciallo-email-dialog h3 { margin: 0; color: #2f241f; font-size: 22px; line-height: 1.25; }
  .ciallo-email-dialog p { margin: 8px 0 14px; color: #665247; line-height: 1.7; }
  .ciallo-email-dialog strong {
    display: block;
    border: 1px solid rgba(230, 114, 73, .2);
    border-radius: 10px;
    padding: 12px;
    background: #fff;
    color: #e67249;
    font-size: 18px;
    word-break: break-all;
  }
  .ciallo-email-actions { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 14px; }
  .ciallo-email-actions button,
  .ciallo-email-actions a {
    min-height: 38px;
    border: 0;
    border-radius: 9px;
    padding: 0 13px;
    background: #e67249;
    color: #fff;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font: inherit;
    font-size: 14px;
    font-weight: 750;
    text-decoration: none;
  }
  .ciallo-email-actions a { background: rgba(230, 114, 73, .12); color: #c95531; }
  @media (prefers-reduced-motion: reduce) {
    .ciallo-email-modal,
    .ciallo-email-dialog { transition: none; }
  }
</style>